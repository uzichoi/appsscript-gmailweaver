ЉИАМІ (МБХУ)\n\n\n\n&gt; АќЗУЕШ НКХЉИАМІРЬ РжДйИщ ПЉБтПЁ УЗКЮЧиСжММПф.\n\n&lt;img width=&quot;1498&quot; height=&quot;738&quot; alt=&quot;image&quot; src=&quot;https://github.com/user-attachments/assets/11ba06ab-beee-4cd1-86c6-a89e5595c238&quot; /&gt;\n\nРкЙАМш И№ОчРЧ authorizeПЁ ХфХЋ ГЛПыРЛ УЗКЮЧиОпЧеДЯДй.\n\n\n\n## #\ufe0f\u20e3 ИЎКф ПфБИЛчЧз (МБХУ)\n\n\n\n&gt; ИЎКфОюАЁ ЦЏКАШї КССжОњРИИщ ЧЯДТ КЮКаРЬ РжДйИщ РлМКЧиСжММПф.\n\n&gt; ПЙНУ: РЬ КЮКаРЧ ФкЕхАЁ Рп РлЕПЧЯДТСі ХзНКЦЎЧи СжНЧ Мі РжГЊПф?\n\n\n\n## \U0001f4ce ТќАэ РкЗс (МБХУ)\n\n\n\n&gt; АќЗУ ЙЎМ­, НКХЉИАМІ, ЖЧДТ ПЙНУ ЕюРЬ РжДйИщ ПЉБтПЁ УЗКЮЧиСжММПф\n\n\n\nYou can view, comment on, or merge this pull request online at:\n\n\n\n  https://github.com/UMC-AlbaLog/Node.JS/pull/14\n\n\n\n-- Commit Summary --\n\n\n\n  * feat(package): ЗЮБзРЮ ЦаХАСі УпАЁ\n\n  * feat(config): РЏРњ РЮСѕ ЦФРЯ УпАЁ\n\n  * feat(express.d.ts): reqПЁ user УпАЁ\n\n  * feat(schema.prisma): ЧСИЎСюИЖ НКХАИЖ userПЁ refreshtokenУпАЁ\n\n  * feat(user_*.ts): ШИПјАЁРд РЮСѕ mvc ЦФРЯ УпАЁ\n\n  * feat(app): appПЁ РЮСѕ ЙЬЕщПўОю УпАЁ\n\n  * feat(tsconfig, tsoa): РЮСѕ Р§ТїПЁ ЧЪПфЧб МГСЄ КЏАц\n\n  * feat(test): ХзНКЦЎ apiПЁМ­ РЮСѕ ХфХЋ ЙпБо\n\n\n\n-- File Changes --\n\n\n\n    A @types/express.d.ts (13)\n\n    M package-lock.json (80)\n\n    M package.json (5)\n\n    M prisma/schema.prisma (3)\n\n    A src/DTO/userDTO.ts (10)\n\n    M src/app.ts (15)\n\n    A src/config/auth.ts (40)\n\n    A src/config/jwt.ts (47)\n\n    M src/config/prisma.ts (16)\n\n    A src/config/tsoa_auth.ts (25)\n\n    M src/controller/test_controller.ts (27)\n\n    A src/controller/user_controller.ts (42)\n\n    A src/repository/user_repository.ts (0)\n\n    A src/service/user_service.ts (0)\n\n    M tsconfig.json (2)\n\n    M tsoa.json (12)\n\n\n\n-- Patch Links --\n\n\n\nhttps://github.com/UMC-AlbaLog/Node.JS/pull/14.patch\n\nhttps://github.com/UMC-AlbaLog/Node.JS/pull/14.diff\n\n\n\n-- \n\nReply to this email directly or view it on GitHub:\n\nhttps://github.com/UMC-AlbaLog/Node.JS/pul